[0.077731, "o", "\r\n\u001b[1;36m== Omni-SAG: policy-gated SSH bastion + tamper-evident evidence ==\u001b[0m\r\n  dev lab: samba-AD (alice in 'dba', bob is not) + MinIO, already running\r\n"]
[1.081849, "o", "\r\n\u001b[1;36m-- starting the gateway --\u001b[0m\r\n$ omni-sag -config config.yaml\r\n"]
[1.60513, "o", "2026/07/14 11:17:29 omni-sag: evidence pipeline active (data_dir=/tmp/claude-1003/-home-rupivbluegreen-projects-omni-sag/ad48e5e6-e2a6-4d42-8c6d-9726d1f39e54/scratchpad/omnisag-demo/evidence, signing key=359b1ba5a59c1b35bc2a16650173680581a5733ff696bf936d53f67e8e4317a1)\r\n2026/07/14 11:17:29 omni-sag listening on 127.0.0.1:2222 (SSH)\r\n"]
[2.609199, "o", "\r\n\u001b[1;36m-- alice (member of AD group 'dba') opens her allowed tunnel --\u001b[0m\r\n$ ssh -L 5432:db1.lab.local:5432 alice@gw   # policy: role dba -> allow\r\n"]
[4.645951, "o", "  tunnel reached the target, HTTP 200\r\n"]
[5.650419, "o", "\r\n\u001b[1;36m-- bob (not in 'dba') tries the same tunnel --\u001b[0m\r\n$ ssh -L 5432:db1.lab.local:5432 bob@gw\r\n"]
[7.686648, "o", "  channel 2: open failed: administratively prohibited: administratively prohibited\r\r\n"]
[8.691989, "o", "\r\n\u001b[1;36m-- stopping the gateway (seals the evidence chain) --\u001b[0m\r\n"]
[8.718101, "o", "  gateway public key: 359b1ba5a59c1b35bc2a16650173680581a5733ff696bf936d53f67e8e4317a1\r\n  chain head:          7ae376663b97d3dd232bdab0c99f3ec1d0d7f71971d895898b9cb715fe2e83d2\r\n"]
[9.721783, "o", "\r\n\u001b[1;36m-- verifying the evidence bundle offline (no gateway running) --\u001b[0m\r\n$ omni-verify -bundle evidence/ -pubkey 359b1ba5a59c1b35bc2a16650173680581a5733ff696bf936d53f67e8e4317a1 -head 7ae376663b97d3dd232bdab0c99f3ec1d0d7f71971d895898b9cb715fe2e83d2\r\n"]
[9.737444, "o", "records:     4\r\nsegments:    1\r\ncheckpoints: 1\r\nsigning key: 359b1ba5a59c1b35bc2a16650173680581a5733ff696bf936d53f67e8e4317a1\r\nchain head:  7ae376663b97d3dd232bdab0c99f3ec1d0d7f71971d895898b9cb715fe2e83d2\r\n\r\nPASS — evidence bundle is intact and authentic.\r\n"]
[11.742202, "o", "\r\n\u001b[1;36m-- an attacker flips one byte in the stored evidence --\u001b[0m\r\n"]
[11.829476, "o", "$ sed -i 's/\"allow\":true/\"allow\":false/' evidence/segments/segment-1-0.jsonl\r\n"]
[12.833907, "o", "\r\n\u001b[1;36m-- re-verifying: the tamper is caught --\u001b[0m\r\n$ omni-verify -bundle evidence/ -pubkey 359b1ba5a59c1b35bc2a16650173680581a5733ff696bf936d53f67e8e4317a1\r\n"]
[12.847813, "o", "records:     4\r\nsegments:    1\r\ncheckpoints: 1\r\nsigning key: 359b1ba5a59c1b35bc2a16650173680581a5733ff696bf936d53f67e8e4317a1\r\nchain head:  7ae376663b97d3dd232bdab0c99f3ec1d0d7f71971d895898b9cb715fe2e83d2\r\n\r\nFAIL — evidence bundle verification failed:\r\n  - TAMPER: segment segment-1-0.jsonl record #0 (emitter=session epoch=1 seq=1 global_seq=1): hash mismatch (stored=284a080f48f4… recomputed=240289d93001…)\r\n  - checkpoint 1-0: Merkle root mismatch (stored=76d487f202cb… recomputed=abcff2aeaa79…)\r\n"]
[13.854905, "o", "\r\n\u001b[1;36m== exit code 1: tampering detected, evidence rejected ==\u001b[0m\r\n"]
