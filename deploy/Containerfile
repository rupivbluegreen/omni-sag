# Multi-stage build for the Omni-SAG gateway on a UBI9 runtime.
#
# Security posture (ADR-0001 / OpenShift restricted-v2):
#   - static binary (CGO disabled), no shell needed at runtime
#   - runs as a non-root user, no added capabilities, no IPC_LOCK / mlock
#   - compatible with a read-only root filesystem
#   - swap-off is a NODE requirement (documented; not enforceable in the image)

# ---- build stage ----
FROM golang:1.25 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# Static, stripped binaries. CGO off so the runtime needs no libc beyond UBI's.
ENV CGO_ENABLED=0 GOOS=linux
RUN go build -trimpath -ldflags="-s -w" -o /out/omni-sag    ./cmd/omni-sag  && \
    go build -trimpath -ldflags="-s -w" -o /out/omnictl     ./cmd/omnictl   && \
    go build -trimpath -ldflags="-s -w" -o /out/omni-verify ./cmd/omni-verify

# ---- runtime stage ----
FROM registry.access.redhat.com/ubi9/ubi-minimal:latest
LABEL org.opencontainers.image.title="omni-sag" \
      org.opencontainers.image.description="Auditable SSH/SFTP privileged-access gateway" \
      org.opencontainers.image.licenses="Apache-2.0"

# A fixed non-root uid/gid (OpenShift also assigns an arbitrary uid; the group
# is 0 so an arbitrary-uid runtime can still read the files).
RUN microdnf -y install shadow-utils && \
    useradd -r -u 10001 -g 0 -s /sbin/nologin omnisag && \
    microdnf -y remove shadow-utils && microdnf clean all

COPY --from=build --chown=10001:0 /out/omni-sag    /usr/local/bin/omni-sag
COPY --from=build --chown=10001:0 /out/omnictl     /usr/local/bin/omnictl
COPY --from=build --chown=10001:0 /out/omni-verify /usr/local/bin/omni-verify

USER 10001
# SSH data plane + control-plane API + metrics (bind addresses come from config).
EXPOSE 2222 8443 9090
ENTRYPOINT ["/usr/local/bin/omni-sag"]
CMD ["-config", "/etc/omni-sag/config.yaml"]
